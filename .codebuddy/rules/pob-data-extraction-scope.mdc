## 数据完整性检查

```python
def validate_extraction_completeness(extracted_data):
    """验证提取数据的完整性"""
    required_stats = {
        'entities': {
            'skill_definition': (1000, 2000),  # 预期范围
            'gem_definition': (500, 1500),
            'stat_mapping': (3000, 7000),
            'passive_node': (3000, 5000)
        },
        'rules': {
            'formula': (100, 1000),
            'modifier': (10000, 50000)
        }
    }
    
    warnings = []
    for category, types in required_stats.items():
        for entity_type, (min_count, max_count) in types.items():
            actual_count = extracted_data[category]['by_type'].get(entity_type, 0)
            if actual_count < min_count:
                warnings.append(f"⚠ {entity_type}数量过少: {actual_count} < {min_count}")
            elif actual_count > max_count:
                warnings.append(f"⚠ {entity_type}数量过多: {actual_count} > {max_count}")
    
    return warnings
```

## 示例：完整提取流程

```python
from pathlib import Path

def extract_all_pob_data(pob_data_dir):
    """完整的POB数据提取流程"""
    
    # Step 1: 提取版本信息
    game_version, pob_version = extract_game_versions(
        f'{pob_data_dir}/GameVersions.lua'
    )
    
    # Step 2: 确定天赋树版本
    latest_tree = get_latest_tree_version(f'{pob_data_dir}/TreeData')
    
    # Step 3: 收集所有文件路径
    all_files = []
    
    # Data目录（所有文件）
    data_dir = Path(f'{pob_data_dir}/Data')
    all_files.extend(data_dir.rglob('*.lua'))
    
    # Modules目录（所有文件）
    modules_dir = Path(f'{pob_data_dir}/Modules')
    all_files.extend(modules_dir.glob('*.lua'))
    
    # 天赋树（仅最新版本）
    tree_file = Path(f'{pob_data_dir}/TreeData/{latest_tree}/tree.lua')
    if tree_file.exists():
        all_files.append(tree_file)
    
    # Step 4: 按优先级排序
    priority_files = prioritize_files(all_files)
    
    # Step 5: 提取数据
    extracted_data = {}
    for file_path in priority_files:
        extract_data_from_file(file_path, extracted_data)
    
    # Step 6: 验证完整性
    warnings = validate_extraction_completeness(extracted_data)
    if warnings:
        log_warnings(warnings)
    
    return extracted_data
```