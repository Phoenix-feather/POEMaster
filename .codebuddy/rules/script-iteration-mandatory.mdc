    def __init__(self, pob_path, db_path, entities_db_path=None):
        # 保持向后兼容
        ...
    
    def extract_all_functions(self):
        """提取所有Lua函数"""
        # v1-v6 功能
        ...
    
    def extract_gap_formulas(self):
